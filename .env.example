# 业务系统登录页
APP_LOGIN_URL=https://dev-contract-agent.qtech.cn/login

# 点击业务系统里的“飞书登录”入口
LOGIN_ENTRY_SELECTOR=text=使用飞书登录

# 优先复用已保存的登录态；文件不存在或失效时会自动回退扫码，并在成功后更新该文件
REUSE_SAVED_AUTH=true
AUTH_STORAGE_STATE_PATH=.auth/feishu-login-state.json
AUTH_STATE_CHECK_TIMEOUT_MS=5000
FORCE_QR_LOGIN=false

# 主流程测试文件与审查参数
REVIEW_FILE_PATH=/Users/shuyi/Downloads/三方合作合同.docx
REVIEW_CONFIG_TIMEOUT_MS=60000
REVIEW_RESULT_TIMEOUT_MS=420000
REVIEW_RETRY_LIMIT=2
CUSTOM_CHECKLIST_LOAD_TIMEOUT_MS=20000
CUSTOM_CHECKLIST_NAMES=舒译测试,默认审查清单
EXPECTED_REVIEW_STANCES=甲方,乙方,丙方

# 默认走扫码登录，你扫码后测试会继续自动断言回跳，并把登录态保存到上面的文件
FEISHU_QR_LOGIN_SELECTOR=text=扫码登录
MANUAL_SCAN_TIMEOUT_MS=180000

# 如果之后想再切回本地 Chrome 缓存账号模式，可以打开下面这些
# REUSE_LOCAL_CHROME_PROFILE=true
# CHROME_USER_DATA_DIR=/Users/shuyi/Library/Application Support/Google/Chrome
# CHROME_PROFILE_DIRECTORY=Default
# FEISHU_ACCOUNT_PICKER_TEXT=王舒译（测试企业-智书 AI 合同审查助手）

# 登录成功断言
# 这个站点前端里存在 /api/v2/smart/public/sso/login 与 localStorage auth/token 逻辑，
# 所以默认先用 JS 断言“已经离开 /login，且 token 或 auth 已经就绪”
LOGIN_SUCCESS_EVAL=window.location.pathname !== '/login' && (Boolean(localStorage.getItem('token')) || localStorage.getItem('auth') === 'true')
LOGIN_SUCCESS_URL_CONTAINS=/home

# 如果你想改成更强的页面断言，也可以改用下面这些
# LOGIN_SUCCESS_SELECTOR=[data-testid='user-avatar']

# 运行参数
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
HEADLESS=false
SLOW_MO=300
UI_TIMEOUT_MS=30000

# 如果默认选择器不匹配，可以按需打开下面这些覆盖项
# FEISHU_AUTHORIZE_SELECTOR=button:has-text('允许')

# 审查清单导入回归可选项
# REVIEW_CHECKLIST_PAGE_URL=https://dev-contract-agent.qtech.cn/review-rule/checkList
# REVIEW_CHECKLIST_API_BASE_URL=https://dev-contract-agent.qtech.cn/api/ai/review-rule/api
# REVIEW_CHECKLIST_TASK_TIMEOUT_MS=300000
# REVIEW_CHECKLIST_OPEN_ATTEMPTS=6
# REVIEW_CHECKLIST_OPEN_WAIT_MS=2000
# REVIEW_CHECKLIST_NAME_PREFIX=insreview_checklist
# REVIEW_CHECKLIST_FIXTURES_DIR=tests/fixtures/review_checklist_import
